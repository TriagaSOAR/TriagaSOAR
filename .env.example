# ── Splunk connection ─────────────────────────────────────────────────────
SPLUNK_HOST=192.168.x.x
SPLUNK_PORT=8089
SPLUNK_TOKEN=your-mcp-encrypted-token-here
SPLUNK_VERIFY_SSL=false

# ── LLM mode: "local" (Ollama) or "cloud" (API) ──────────────────────────
LLM_MODE=local

# ── Local mode — Ollama ───────────────────────────────────────────────────
# Only used when LLM_MODE=local
OLLAMA_HOST=http://localhost:11434
REASONER_MODEL=qwen3:14b
ROUTER_MODEL=qwen3:1.7b

# ── Cloud mode ────────────────────────────────────────────────────────────
# Only used when LLM_MODE=cloud
# Provider: "openai" or "anthropic"
CLOUD_PROVIDER=openai
# OpenAI model examples: gpt-4o, gpt-4o-mini, o1
# Anthropic model examples: claude-sonnet-4-6, claude-haiku-4-5-20251001
CLOUD_MODEL=gpt-4o
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────
DB_PATH=/app/data/cases.db

# ── Saved search monitor ──────────────────────────────────────────────────
MONITOR_ENABLED=false
MONITOR_INTERVAL_SECONDS=60
MONITOR_COOLDOWN_MINUTES=5

# ── Threat intelligence (optional) ───────────────────────────────────────
# Get a free API key at https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=