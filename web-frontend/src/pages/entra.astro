---
import BaseLayout from "../layouts/BaseLayout.astro";
import EntraPanel from "../components/EntraPanel";
---

<BaseLayout title="Entra ID">
  <div style="max-width: 1100px; margin: 0 auto; padding: 32px 24px;">
    <div style="margin-bottom: 28px;">
      <div style="font-family: monospace; font-size: 11px; color: #888; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.08em;">
        Identity Intelligence
      </div>
      <h1 style="font-size: 24px; font-weight: 700; margin: 0 0 6px 0;">Microsoft Entra ID</h1>
      <p style="color: #888; margin: 0; font-size: 14px;">
        Risky users, risk detections, security alerts, and response actions via Microsoft Graph.
      </p>
    </div>
    <EntraPanel client:load />
  </div>
</BaseLayout>