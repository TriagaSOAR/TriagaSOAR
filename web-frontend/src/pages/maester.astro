---
import BaseLayout from "../layouts/BaseLayout.astro";
import MaesterPanel from "../components/MaesterPanel";
---

<BaseLayout title="Maester">
  <div style="max-width: 1100px; margin: 0 auto; padding: 32px 24px;">
    <div style="margin-bottom: 28px;">
      <div style="font-family: monospace; font-size: 11px; color: #888; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.08em;">
        M365 Security Posture
      </div>
      <h1 style="font-size: 24px; font-weight: 700; margin: 0 0 6px 0;">Maester</h1>
      <p style="color: #888; margin: 0; font-size: 14px;">
        Microsoft 365 security configuration tests — CIS, EIDSCA, CISA benchmarks via Maester 2.x.
      </p>
    </div>
    <MaesterPanel client:load />
  </div>
</BaseLayout>