---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import PlaybooksPanel from "../components/PlaybooksPanel";
---
<BaseLayout title="Playbooks">
  <div style="max-width: 1100px; margin: 0 auto; padding: 32px 24px;">
    <div style="margin-bottom: 28px;">
      <div style="font-family: monospace; font-size: 11px; color: #888; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.08em;">
        Automation
      </div>
      <h1 style="font-size: 24px; font-weight: 700; margin: 0 0 6px 0;">Playbooks</h1>
      <p style="color: #888; margin: 0; font-size: 14px;">
        YAML-based auto-response rules. Evaluated after every investigation — matching playbooks execute automatically.
      </p>
    </div>
    <PlaybooksPanel client:load />
  </div>
</BaseLayout>